+	fi.interval.denominator = a->parm.capture.timeperframe.denominator;
+
+	if (media_pad_remote_pad_first(&av->pad))
+		ret = media_pipeline_enumerate_by_stream_cb(av,
+			ipu7_isys_set_parm_subdev, &fi);
+
+	return ret;

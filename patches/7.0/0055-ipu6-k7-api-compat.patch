@@ -102,7 +102,12 @@ int ipu_isys_csi2_get_link_freq(struct ipu_isys_csi2 *csi2, s64 *link_freq)
 	bpp = ipu_isys_mbus_code_to_bpp(csi2->asd.ffmt->code);
 	lanes = csi2->nlanes;
 
+
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(7, 0, 0)
